# ---- Database (Neon Postgres via Vercel Marketplace) ----
# Vercel's Neon integration provisions this automatically on deploy.
# Locally: `vercel env pull .env.local` after linking the project.
DATABASE_URL=

# ---- Auth.js (NextAuth v5) ----
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=
# Google OAuth client (https://console.cloud.google.com → Credentials → OAuth client ID, "Web application")
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google  (and your prod URL)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- Vercel AI Gateway ----
# https://vercel.com/dashboard → AI Gateway → API key.
# On Vercel deployments this is injected automatically (OIDC); set it for local dev.
AI_GATEWAY_API_KEY=
# Optional model override (defaults to anthropic/claude-sonnet-4.6)
AI_MODEL=anthropic/claude-sonnet-4.6

# ---- Vercel Blob (photo storage) ----
# Auto-injected on Vercel. Locally: create a Blob store and `vercel env pull`.
BLOB_READ_WRITE_TOKEN=
